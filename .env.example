# Email Configuration for TeamAI
# Copy this file to .env and fill in your actual credentials

# SMTP (for sending task emails and reminders)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here

# IMAP (for receiving forwarded emails)
TEAMAI_EMAIL=your-email@gmail.com
TEAMAI_EMAIL_PASSWORD=your-app-password-here
IMAP_SERVER=imap.gmail.com
EMAIL_POLLING_INTERVAL=30

# K2 API - api.k2think.ai
K2_API_KEY=your-k2-api-key-here
K2_THINK_BASE_URL=https://api.k2think.ai/v1
K2_THINK_MODEL=MBZUAI-IFM/K2-Think-v2

# Notion
NOTION_API_KEY=your-notion-api-key
NOTION_DATABASE_ID=30a4529e-75ee-80b0-8e33-e1d6c582a95c

# OpenClaw (disabled)
USE_OPENCLAW=false
OPENCLAW_BASE_URL=http://localhost:18789
OPENCLAW_TOKEN=

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
