# TeamAI Production Environment Configuration
# Copy this file to .env and fill in the values

# ============================================
# K2 API Configuration (REQUIRED)
# ============================================
K2_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXX
K2_THINK_BASE_URL=http://build-api-2.ifmapp.net:8000
K2_INSTRUCT_BASE_URL=http://instruct-api-3.ifmapp.net:8000
K2_THINK_MODEL=LLM360/K2-Think-V2
K2_INSTRUCT_MODEL=LLM360/K2-V2-Instruct

# ============================================
# Notion Integration (REQUIRED for task sync)
# ============================================
# Get your API key from: https://www.notion.so/my-integrations
NOTION_API_KEY=ntn_XXXXXXXXXXXXXXXXXXXXXXXXXXX
# Your Tasks Tracker database ID (from the URL when viewing the database)
NOTION_DATABASE_ID=30a4529e-75ee-80b0-8e33-e1d6c582a95c

# ============================================
# Email Configuration (OPTIONAL)
# ============================================
# For sending task notifications and processing forwarded emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=teamaiassistant@gmail.com
# Use Gmail App Password: https://myaccount.google.com/apppasswords
SMTP_PASS=xxxx_xxxx_xxxx_xxxx

# Email forwarding inbox
TEAMAI_EMAIL=teamaiassistant@gmail.com
TEAMAI_EMAIL_PASSWORD=xxxx_xxxx_xxxx_xxxx
IMAP_SERVER=imap.gmail.com
EMAIL_POLLING_INTERVAL=30

# ============================================
# Telegram Notifications (OPTIONAL)
# ============================================
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ============================================
# OpenClaw Integration (OPTIONAL)
# ============================================
USE_OPENCLAW=false
OPENCLAW_BASE_URL=http://localhost:18789
OPENCLAW_TOKEN=

# ============================================
# Application Settings
# ============================================
PORT=8001

# ============================================
# Security (Add in production)
# ============================================
# API_KEY=your-secure-api-key-for-production
# CORS_ORIGINS=https://your-domain.com
